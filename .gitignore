# Python
.venv/
__pycache__/
.pytest_cache/
*.egg-info/
*.pyc

# Coverage tooling output
.coverage
.coverage.*
htmlcov/

# Logs
*.log

# Claude Code session artifacts
.claude/
.playwright-mcp/

# Reference materials (large; tracked by metadata only)
ref/papers/*.pdf
ref/pages/*.html

# Codex extracted-content blobs (large; metadata in ref/SOURCE_MANIFEST.md is enough)
gpt-codex/extracted/
gpt-codex/sources/

# gpt-codex/runs/ retention policy (audit-F2):
# - NEW run dirs are gitignored by default. Already-tracked Phase 1-10 evidence
#   STAYS TRACKED — git's gitignore patterns don't affect files that are already
#   in the index, so no destructive untracking happens here.
# - To promote a new run when a verdict cites it (`docs/artifacts/PHASE_*.md`),
#   force-add it: `git add -f gpt-codex/runs/<dir>/`.
# - See docs/MANIFESTO.md § gpt-codex/runs/ retention policy for criteria.
gpt-codex/runs/*/

# sandbox/ runtime artifacts (Phase 13 cycle 2 D4 fresh-catch; refined 2026-05-12):
# - The agent (Project X Raphael) writes verification scripts + intermediate
#   artifacts to sandbox/workdir/ via the action-taking primitives. These are
#   runtime artifacts, NOT deliverables.
# - Named snapshots in sandbox/.snapshots/ are also runtime state.
# - The Python source under sandbox/ (agent_io.py, __init__.py) IS tracked —
#   it's the substrate's action-taking infrastructure.
sandbox/workdir/
sandbox/.snapshots/

# Cycle 12 #00P13c12-02 — audit log runtime data
# (directory tracked via .gitkeep so it exists on fresh clone; JSONL contents
# are per-instance lain feedback on emitted walks, not source-controlled)
data/audit_log/*.jsonl
